# ─────────────────────────────────────────────────────────────────────────
# ProTutor CRM — Backend Environment Variables
# Copy this file to ".env" for local development, and set the SAME variables
# in your Vercel project settings for production.
# NEVER commit the real .env file or real values to Git.
# ─────────────────────────────────────────────────────────────────────────

# Supabase project URL (Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase SERVICE ROLE key — full database access, keep secret.
# Rotate this if it was ever committed to Git or shared.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Secret used to sign login tokens. Generate a fresh random one with:
#   openssl rand -hex 32
JWT_SECRET=your_random_64_char_secret_here

# How long a login stays valid (e.g. 8h, 1d, 30m). Optional, defaults to 8h.
JWT_EXPIRES_IN=8h

# Comma-separated list of front-end origins allowed to call this API.
# Example: https://crm.protutor.in,https://www.protutor.in
# Leave unset only for local development.
ALLOWED_ORIGINS=https://crm.protutor.in
