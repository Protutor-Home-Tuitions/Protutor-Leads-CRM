# ═══════════════════════════════════════════════════════════════
# ProTutor CRM — Backend .env
# Rename this file to .env and fill in your values.
# NEVER commit .env to git. Add .env to your .gitignore.
# ═══════════════════════════════════════════════════════════════


# ── DATABASE (Supabase) ─────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:Viky@1995SupaBase@db.baddtkhuvgymwqmetoxg.supabase.co:5432/postgres

# Individual fields (use these if your pg pool config reads them separately)
DB_HOST=db.baddtkhuvgymwqmetoxg.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=Viky@1995SupaBase

# SSL is required for Supabase — set to true
DB_SSL=true


# ── SUPABASE KEYS ───────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://baddtkhuvgymwqmetoxg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJhZGR0a2h1dmd5bXdxbWV0b3hnIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDc4NTQxNSwiZXhwIjoyMDkwMzYxNDE1fQ.QSznISHx2Jr-fHRlAA4DD1GTo51GIZlMt_9OHCMvBoQ   # Full access key — NEVER expose to browser
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJhZGR0a2h1dmd5bXdxbWV0b3hnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ3ODU0MTUsImV4cCI6MjA5MDM2MTQxNX0._RflfwGMYuqahmRrLZzGutu_2X4dU6jzBS6bJ3RhmOc           # Limited key — safe for public use


# ── JWT AUTH ────────────────────────────────────────────────────
# Used to sign and verify login tokens.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=8h          # Token expires after 8 hours — user must log in again


# ── SERVER ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development       # Change to "production" when deployed


# ── CORS ────────────────────────────────────────────────────────
# URL(s) your frontend is served from — backend will allow requests from here
# Separate multiple origins with a comma
ALLOWED_ORIGINS=http://localhost:3000,https://leads.protutor.in


# ═══════════════════════════════════════════════════════════════
# INTEGRATIONS — all optional, leave blank to disable
# ═══════════════════════════════════════════════════════════════


# ── CLIENT DB CHECK (Integration 1a) ───────────────────────────
# Your main DB endpoint that checks if a phone number is a client.
# POST { phones: string[] } → { clientPhones: [{ phone, name }] }
# Leave blank to disable the Client badge feature.
CLIENT_CHECK_URL=


# ── TUTOR DB CHECK (Integration 1b) ────────────────────────────
# Checked only for phones NOT found in client DB.
# POST { phones: string[] } → { tutorPhones: [{ phone, name }] }
# Leave blank to disable the Tutor badge feature.
TUTOR_CHECK_URL=


# ── NEW LEAD SYNC (Integration 2) ──────────────────────────────
# Your main DB endpoint that returns leads added since a timestamp.
# POST { since: "2026-03-29T10:00:00Z" } → { leads: [...] }
# Leave blank to disable auto-sync from main DB.
NEW_LEADS_SYNC_URL=


# ── WATI (Integration 3 & 4) ───────────────────────────────────
# WhatsApp Business API via WATI.
# Get from: WATI Dashboard → API → Endpoint and Token
WATI_API_URL=                      # e.g. https://live-server-XXXXX.wati.io
WATI_API_TOKEN=                    # Bearer token from WATI dashboard

# Template names — must match exactly what you created in WATI
# Used when a call log is saved (lead or call data)
WATI_TEMPLATE_CALL_LOG=""

# Used when a new number is added to Call Data
WATI_TEMPLATE_NEW_NUMBER=


# ═══════════════════════════════════════════════════════════════
# WEBSITE LEAD WEBHOOK (inbound)
# ═══════════════════════════════════════════════════════════════
# A shared secret your website sends in the header when posting new leads.
# Your backend checks this before accepting a new lead from the website.
# Header: X-Webhook-Secret: <value below>
WEBHOOK_SECRET=replace_with_a_random_secret_string
